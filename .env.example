# Database
MYSQL_USER=portal
MYSQL_PASSWORD=CHANGE_ME_strong_password_here
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password_here

# JWT
JWT_SECRET=CHANGE_ME_use_64_char_random_string
JWT_EXPIRY=1h
JWT_COOKIE_MAX_AGE_MS=3600000

# Session Reset
RESET_SESSION_SECRET=CHANGE_ME_use_random_string

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost
FRONTEND_URLS=http://localhost
